# Copia este ficheiro para .env.local e preenche com os teus valores reais.
# NUNCA comites o .env.local (já está no .gitignore).

# --- Supabase ---
# Encontras estes valores em: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...a-chave-publica-anon...
# Chave privada — NUNCA expor ao browser. Só usada em scripts/API routes do servidor.
SUPABASE_SERVICE_ROLE_KEY=eyJ...a-chave-privada-service-role...

# --- EasyPay ---
# Pedidos estes valores ao EasyPay depois de criares conta em https://www.easypay.pt
EASYPAY_ACCOUNT_ID=o-teu-account-id
EASYPAY_API_KEY=a-tua-api-key
# Ambiente: 'test' (sandbox, sem dinheiro real) ou 'prod' (produção, pagamentos reais)
EASYPAY_ENV=test

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
